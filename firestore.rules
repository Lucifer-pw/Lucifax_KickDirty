rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isOwnerOrStaff());
    }

    // ============================================
    // PHONE LOOKUPS COLLECTION (WhatsApp login helper)
    // ============================================
    match /phone_lookups/{phone} {
      allow read, create: if true;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.uid || isOwnerOrStaff());
    }

    // ============================================
    // SERVICES COLLECTION (pricing list)
    // ============================================
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // ORDERS COLLECTION
    // Fitur: Pesanan, Ulasan Pelanggan, Moderasi Review, Trust Counter Stats
    // - get: Authenticated users bisa baca semua order.
    //        Unauthenticated web visitors bisa baca order yang showOnWeb == true (ulasan publik).
    // - list: Authenticated users bisa query semua order (stats, riwayat, moderasi).
    //         Unauthenticated web visitors bisa query order yang showOnWeb == true (carousel ulasan).
    // - create: Hanya user yang login bisa buat pesanan baru.
    // - update: User login bisa update (submit ulasan, update status, toggle showOnWeb moderasi).
    // - delete: Hanya Owner/Staff/Developer yang boleh hapus pesanan.
    // ============================================
    match /orders/{orderId} {
      allow get: if request.auth != null
                 || (resource != null && resource.data.showOnWeb == true);
      allow list: if request.auth != null
                  || (resource != null && resource.data.showOnWeb == true);
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // EXPENSES COLLECTION
    // ============================================
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // APP CONFIG (version_info, etc)
    // ============================================
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // LOGISTICS METHODS COLLECTION
    // ============================================
    match /logistics_methods/{methodId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // VOUCHERS COLLECTION
    // ============================================
    match /vouchers/{voucherId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOwnerOrStaff();
    }

    // ============================================
    // COUNTERS COLLECTION (invoice number generator)
    // ============================================
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // CUSTOMERS COLLECTION (customer database records)
    // ============================================
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == customerId || isOwnerOrStaff());
    }

    // ============================================
    // CHAT ROOMS COLLECTION
    // ============================================
    match /chat_rooms/{chatRoomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && isOwnerOrStaff();

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwnerOrStaff();
      }
    }

    // ============================================
    // DEVELOPER BILLING CONFIG COLLECTION
    // ============================================
    match /developer_billing/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isDeveloper();
    }

    // ============================================
    // DEVELOPER BILLING INVOICES COLLECTION
    // ============================================
    match /developer_billing_invoices/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    function isOwnerOrStaff() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'staff', 'developer'];
    }

    function isDeveloper() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer';
    }
  }
}
